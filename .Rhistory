– my_first <- "ilhan" – my_birth_year <- 2002
my_first <- "ilhan"
my_birth_year <- 2002
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
##k is even, so display the first k rows
install(dslabs)
install.packages(dslabs)
install.packages("dslabs")
library(dslabs)
data("polls_us_election_2016")
force(polls_us_election_2016)
force(results_us_election_2016)
(head(data,k))
head(data, k)
View(polls_us_election_2016)
head(polls_us_election_2016, k)
poll <- polls_us_election_2016
total_na <- sum(is.na(poll))
total_na
na_per_column <- colSums(is.na(poll))
na_per_column
na_sorted <- sort(na_per_column, decreasing = TRUE)
na_sorted
top_8_na <- head(na_sorted, 8)
top_8_na
##because we were told not to change the original data, we define a copy
new_data <- poll
numeric_value <- my_birth_year + k
text_value <- paste0(my_first, "_", k)
for(col in names(new_data)){
if(is.numeric(new_data[[col]][is.n(new_data[[col]])] <- numeric_value
}
for(col in names(new_data)){
if(is.numeric(new_data[[col]])){
new_data[[col]][is.na(new_data[[col]])] <- numeric_value
}
}
for(col in names(new_data)){
if(is.character(new_data[[col]])){
new_data[[col]][is.na(new_data[[col]])] <- text_value
}
if(is.factor(new_data[[col]])){
new_data[[col]] <- as.character(new_data[[col]])
new_data[[col]][is.na(new_data[[col]])] <- text_value
}
}
anyNA(new_data)
